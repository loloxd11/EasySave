<Window x:Class="EasySave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EasySave" Height="600" Width="900" Background="#f4f4f4" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Top bar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="EASYSAVE BY PROSOFT" 
                   FontSize="32" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,10,0,20" 
                   Foreground="#333"/>

        <!-- Top bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button x:Name="SettingsButton" Content="⚙ Settings" Width="100" Margin="0,0,10,0"
                    Click="SettingsButton_Click" Background="#ddd" BorderBrush="#aaa" Padding="5" />

            <!-- Language menu hidden by default -->
            <StackPanel x:Name="LanguageMenu" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                <Button Tag="fr" Click="LanguageButton_Click" Margin="5" Padding="5" Background="#ffffff">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="24" Height="16" Source="/Assets/fr.png" Margin="0,0,5,0"/>
                        <TextBlock Text="Français"/>
                    </StackPanel>
                </Button>
                <Button Tag="en" Click="LanguageButton_Click" Margin="5" Padding="5" Background="#ffffff">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="24" Height="16" Source="/Assets/en.png" Margin="0,0,5,0"/>
                        <TextBlock Text="English"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Main area -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="20">
            <DataGrid x:Name="LanguagePanel" AutoGenerateColumns="False" Height="300" Margin="0,0,0,20"
                      CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Source" Binding="{Binding SourcePath}" Width="2*"/>
                    <DataGridTextColumn Header="Cible" Binding="{Binding TargetPath}" Width="2*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="*"/>
                    <DataGridTextColumn Header="État" Binding="{Binding Status}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <WrapPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Ajouter" Click="AddBackupJob_Click" Margin="10" Padding="10,5" Background="#5cb85c" Foreground="White"/>
                <Button Content="Modifier" Click="EditBackupJob_Click" Margin="10" Padding="10,5" Background="#0275d8" Foreground="White"/>
                <Button Content="Supprimer" Click="DeleteBackupJob_Click" Margin="10" Padding="10,5" Background="#d9534f" Foreground="White"/>
                <Button Content="Exécuter" Click="ExecuteBackupJob_Click" Margin="10" Padding="10,5" Background="#f0ad4e" Foreground="White"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>